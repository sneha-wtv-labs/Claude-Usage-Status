{
  "manifest_version": 3,
  "name": "Claude Usage Info",
  "description": "Shows token count, cache timer, usage bar on Claude.ai message bar.",
  "version": "0.1",
  "author": "Sneha",
  "homepage_url": "https://github.com/sneha-wtv-labs/Claude-Usage-Status",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://*.claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["*://*.claude.ai/*"],
    "js": ["content.js"],
    "css": ["style.css"],
    "run_at": "document_start",
    "all_frames": true
  }]
}
